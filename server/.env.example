PORT=8080
CLIENT_ORIGIN=http://localhost:5173
JWT_SECRET=change-this-secret

# FREE local AI chat with Ollama
AI_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b

# Optional paid OpenAI features: cloud chat, image generation, server voice/STT
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-4.1-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_STT_MODEL=gpt-4o-transcribe

# Email OTP SMTP. Leave blank for console OTP testing.
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Premium AI <yourgmail@gmail.com>"
OTP_EXPIRES_MINUTES=10

# Free web image provider for development. Use openai for paid OpenAI image generation.
IMAGE_PROVIDER=pollinations

# Free cloud AI chat with Groq
# Set AI_PROVIDER=groq to use this provider
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
